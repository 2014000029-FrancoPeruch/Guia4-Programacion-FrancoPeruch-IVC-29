Algoritmo Lecc9_Act2_Inc1
	Definir mon Como Entero
	mon <- 0
	montot = 0
	Mientras montot < 350 Hacer
		Escribir '======================'
		Escribir 'Nivel 5 BLOQUEADO'
		Escribir '======================'
		Escribir 'Cantidad de monedas: ', montot
		Escribir Sin Saltar 'Ingrese la cantidad de monedas: '
		Leer mon
		montot = montot + mon
	FinMientras
	
	Escribir '======================'
	Escribir 'Nivel 5 DESBLOQUEADO'
	Escribir '======================'
FinAlgoritmo
